gibbs_sampling <- function(n, y_init, p, burn=.18) {
total_samples = floor(n / (1 - burn))
samples <- matrix(0, nrow=total_samples, ncol=2)
# Get the y values
y1 <- y_init[1]
y2 <- y_init[2]
# Initialize mu at the initial y
mu1 <- y_init[1]
mu2 <- y_init[2]
m = floor(total_samples * burn)
for(sample in 1:total_samples) {
mu1 <- rnorm(1, mean=y1 + p*(mu2-y2), sd=sqrt(1-p^2))
mu2 <- rnorm(1, mean=y2 + p*(mu1-y1), sd=sqrt(1-p^2))
samples[sample, ] <- c(mu1, mu2)
}
return(samples[(m+1):total_samples,])
}
gibbs_samples = gibbs_sampling(n=10000, y_init=y, p=-.6)
gibbs_samples
gibbs_sampling <- function(n, y_init, rho, burn=.18) {
total_samples = floor(n / (1 - burn))
samples <- matrix(0, nrow=total_samples, ncol=2)
# Get the y values
y1 <- y_init[1]
y2 <- y_init[2]
# Initialize mu at the initial y
mu1 <- y_init[1]
mu2 <- y_init[2]
m = floor(total_samples * burn)
for(sample in 1:total_samples) {
mu1 <- rnorm(1, mean=y1 + rho*(mu2-y2), sd=sqrt(1-rho^2))
mu2 <- rnorm(1, mean=y2 + rho*(mu1-y1), sd=sqrt(1-rho^2))
samples[sample, ] <- c(mu1, mu2)
}
return(samples[(m+1):total_samples,])
}
set.seed(42)
gibbs_samples = gibbs_sampling(n=10000, y_init=y, rho=-.6)
# Plot convergence
