# Theoretical joint: p(y, θ) = p(y|θ) * p(θ) = Binomial(y|θ,1) * p(θ)
theta_grid <- seq(0.001, 0.999, length.out=500)
# Compute theoretical joint for y=0 and y=1
p_y1_theta <- dbinom(1, size=1, prob=theta_grid) * p(theta_grid)  # p(y=1, θ)
p_y0_theta <- dbinom(0, size=1, prob=theta_grid) * p(theta_grid)  # p(y=0, θ)
theory_df <- data.frame(
theta = rep(theta_grid, 2),
density = c(p_y1_theta, p_y0_theta),
y = factor(rep(c("y=1", "y=0"), each=length(theta_grid)))
)
# Plot 1: Theoretical joint distribution
ggplot(theory_df, aes(x=theta, y=density, color=y)) +
geom_line(lwd=1) +
scale_color_manual(values=c("blue", "red")) +
labs(title="Theoretical Joint Distribution p(y, θ)",
x="θ", y="p(y, θ)") +
theme_minimal()
